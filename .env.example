PORT=8765
# Bind address. 0.0.0.0 exposes on every interface (Tailscale + LAN) — the
# intended default so other local machines can reach the bridge. Use
# 127.0.0.1 for localhost-only, or your Tailscale IP for tailnet-only.
HOST=0.0.0.0
BROWSER=Google Chrome
# Generate with: openssl rand -hex 32
BRIDGE_TOKEN=replace-me-with-a-64-char-hex-string
