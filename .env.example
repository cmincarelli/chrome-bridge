PORT=8765
# Bind address. Use 127.0.0.1 for localhost-only, your Tailscale IP for
# Tailscale-only access, or 0.0.0.0 to expose on every interface (LAN + any
# public Wi-Fi the host joins). Be careful with 0.0.0.0.
HOST=127.0.0.1
BROWSER=Google Chrome
# Generate with: openssl rand -hex 32
BRIDGE_TOKEN=replace-me-with-a-64-char-hex-string
